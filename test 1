    def _bj_btn(self, parent, text, color, cmd):
        f = tk.Frame(parent, bg=color, cursor="hand2")
        f.pack(side="left", padx=10, fill="x", expand=True)
        l = tk.Label(f, text=text, fg=WHITE, bg=color,
