        self.create_custom_btn(self.btn_frame, "HIT", "#0A84FF", self.bj_hit)
        self.create_custom_btn(self.btn_frame, "STAND", "#D32F2F", self.bj_stand)

        self.post_game_frame = tk.Frame(self.bj_window, bg="#1A2837")
