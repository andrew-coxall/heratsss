    def __init__(self, parent, controller):
        super().__init__(parent, bg="#121212")
        self.controller = controller
        self.user = controller.user
        self.current_tip = 0

        self.status_bar = tk.Label(self, text="", fg="white", bg="#00D084", font=("Helvetica", 10, "bold"), pady=5)
        self.status_bar.pack(fill="x")
        self.status_bar.pack_forget()

        tk.Label(self, text=f"Welcome back, {self.user.name}", fg="#888", bg="#121212", font=("Helvetica", 10)).pack(pady=(15, 0))

        self.card = tk.Frame(self, bg="#1E1E1E", padx=20, pady=25, highlightthickness=1, highlightbackground="#333")
