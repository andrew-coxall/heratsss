def make_modal(root, w=390, h=700, title="SwiftPay", bg=BG):
    win = tk.Toplevel(root)
    win.geometry(f"{w}x{h}")
    win.resizable(False, False)
    win.configure(bg=bg)
    win.transient(root)
    win.grab_set()
    bar = tk.Frame(win, bg="#0F0F0F", pady=14)
    bar.pack(fill="x")
    tk.Label(bar, text=title, fg=WHITE, bg="#0F0F0F",
             font=("Helvetica", 13, "bold")).pack()
    tk.Frame(win, bg=BORDER, height=1).pack(fill="x")
    return win

def flat_btn(parent, text, bg, fg, cmd,
             pady=13, font_size=12, padx=30, fill="x"):
    f = tk.Frame(parent, bg=bg, cursor="hand2")
    f.pack(pady=5, padx=padx, fill=fill)
    l = tk.Label(f, text=text, fg=fg, bg=bg,
                 font=("Helvetica", font_size, "bold"), pady=pady)
    l.pack()
    for w in (f, l):
        w.bind("<Button-1>", lambda e, c=cmd: c())
    return f

def card_frame(parent, padx=20, pady=6):
    outer = tk.Frame(parent, bg=CARD, highlightthickness=1,
                     highlightbackground=BORDER)
    outer.pack(fill="x", padx=padx, pady=pady)
    inner = tk.Frame(outer, bg=CARD, padx=16, pady=14)
    inner.pack(fill="x")
    return inner

def section_label(parent, text, padx=24, pady=(14, 4)):
    tk.Label(parent, text=text, fg="#3A3A3A", bg=BG,
             font=("Helvetica", 8, "bold")).pack(
             anchor="w", padx=padx, pady=pady)

def subtle_link(parent, text, cmd, fg="#2A2A2A"):
    f = tk.Frame(parent, bg=BG, cursor="hand2")
    f.pack(pady=3)
    l = tk.Label(f, text=text, fg=fg, bg=BG,
                 font=("Helvetica", 8, "underline"))
    l.pack()
    for w in (f, l): w.bind("<Button-1>", lambda e, c=cmd: c())
    return f


