    def _cancel_step2(self):
        w = SwiftPayApp.make_modal(self, h=520, title="Before You Go")
        tk.Label(w, text="We'd hate to see you go 😢", fg="white", bg="#0D0D0D",
                 font=("Helvetica", 16, "bold")).pack(pady=(32, 10))
        tk.Label(w, text="You'll lose access to:", fg="#888", bg="#0D0D0D",
                 font=("Helvetica", 11)).pack()
        for feat in ["Balance Shield — your overdraft safety net",
                     "Lightning Speed transfers",
                     "SwiftScore credit building",
                     "Casino & rewards"]:
            tk.Label(w, text=f"✗  {feat}", fg="#FF4500", bg="#0D0D0D",
                     font=("Helvetica", 10)).pack(pady=2)
        SwiftPayApp.flat_btn(w, "Keep My Membership", "#00D47E", "#000",
                             lambda: w.destroy())
        cf = tk.Frame(w, bg="#0D0D0D", cursor="hand2"); cf.pack(pady=4)
        cl = tk.Label(cf,
                      text="I understand I'll lose these benefits — continue",
                      fg="#2A2A2A", bg="#0D0D0D",
                      font=("Helvetica", 8, "underline"))
        cl.pack()
        for widget in (cf, cl):
            widget.bind("<Button-1>", lambda e: [w.destroy(), self._cancel_step3()])

    def _cancel_step3(self):
        w = SwiftPayApp.make_modal(self, h=480, title="One Moment")
        tk.Label(w, text="Tell us why you're leaving", fg="white", bg="#0D0D0D",
                 font=("Helvetica", 15, "bold")).pack(pady=(32, 16))
        reasons = ["Too expensive", "Don't use it enough",
                   "Found another service", "Other"]
        self._cancel_reason = tk.StringVar(value=reasons[0])
        for r in reasons:
            tk.Radiobutton(w, text=r, variable=self._cancel_reason, value=r,
                           fg="#888", bg="#0D0D0D", selectcolor="#0D0D0D",
                           activebackground="#0D0D0D",
                           font=("Helvetica", 11)).pack(anchor="w", padx=40, pady=4)
        SwiftPayApp.flat_btn(w, "Submit & Continue Cancellation",
                             "#1A1A1A", "#666",
                             lambda: [w.destroy(), self._cancel_step4()])

    def _cancel_step4(self):
        w = SwiftPayApp.make_modal(self, h=460, title="Special Offer")
        tk.Label(w, text="Wait — a special offer just for you!",
                 fg="#FF8C00", bg="#0D0D0D",
                 font=("Helvetica", 15, "bold")).pack(pady=(32, 10))
        tk.Label(w, text="Stay for 3 more months at\n$0.99/month — 50% off!",
                 fg="white", bg="#0D0D0D",
                 font=("Helvetica", 18, "bold"), justify="center").pack(pady=10)
        SwiftPayApp.flat_btn(w, "Accept Offer — Stay at $0.99/mo",
                             "#FF8C00", "#000",
                             lambda: [w.destroy(),
                                      self.show_toast("Offer accepted!", "#FF8C00")])
        cf = tk.Frame(w, bg="#0D0D0D", cursor="hand2"); cf.pack(pady=6)
        cl = tk.Label(cf, text="No thanks — I really want to cancel",
                      fg="#1E1E1E", bg="#0D0D0D",
                      font=("Helvetica", 8, "underline"))
        cl.pack()
        for widget in (cf, cl):
            widget.bind("<Button-1>", lambda e: [w.destroy(), self._cancel_step5()])

    def _cancel_step5(self):
        w = SwiftPayApp.make_modal(self, h=400, title="Confirm Cancellation")
        tk.Label(w, text="Are you absolutely sure?", fg="white", bg="#0D0D0D",
                 font=("Helvetica", 16, "bold")).pack(pady=(40, 12))
        tk.Label(w,
                 text="Your membership will cancel at the end of your current "
                      "billing period.\n\nYou will still be charged $1.99 for this period.",
                 fg="#888", bg="#0D0D0D", font=("Helvetica", 10),
                 justify="center").pack()
        SwiftPayApp.flat_btn(w, "Yes, Cancel Membership", "#1A1A1A", "#FF4500",
                             lambda: [w.destroy(),
                                      self.show_toast("Membership cancelled.", "#FF4500")])
        SwiftPayApp.flat_btn(w, "Keep My Membership", "#00D47E", "#000",
                             lambda: w.destroy())


