    def _show_settings(self):
        w = make_modal(self, h=680, title="Settings")

        # Account section
        section_label(w, "ACCOUNT", padx=20, pady=(12, 4))
        self._settings_row(w, "Name", self.user.name, None)
        self._settings_row(w, "Linked Bank", self.user.linked_bank,
                           lambda: self.show_toast("Bank linking coming soon.", ORANGE))
        self._settings_row(w, "Email", "alice@example.com", None)

        # Preferences
        section_label(w, "PREFERENCES", padx=20, pady=(12, 4))

        # Notification toggle — turning off removes "protection" framing
        notif_row = tk.Frame(w, bg=CARD,
                             highlightthickness=1, highlightbackground="#1A1A1A")
        notif_row.pack(fill="x", padx=20, pady=2)
        nri = tk.Frame(notif_row, bg=CARD, padx=16, pady=12); nri.pack(fill="x")
        tk.Label(nri, text="Notifications", fg=MUTED2, bg=CARD,
                 font=("Helvetica", 11)).pack(side="left")
        self._notif_var = tk.BooleanVar(value=self.user.notif_enabled)
        # Styled toggle (Checkbutton styled as switch)
        toggle = tk.Checkbutton(nri, variable=self._notif_var,
                                text="", bg=CARD, activebackground=CARD,
                                selectcolor=CARD,
                                command=self._toggle_notifications)
        toggle.pack(side="right")
        # Warning if disabled
        self._notif_warning = tk.Label(w,
            text="⚠️  Disabling notifications may cause you to miss repayment "
                 "deadlines and incur late fees.",
            fg=ORANGE, bg=BG, font=("Helvetica", 8),
            wraplength=340, justify="left")

        self._settings_row(w, "Face ID / Touch ID", "Enabled", None)
        self._settings_row(w, "SwiftPay+ Membership", "$1.99/mo",
                           lambda: [w.destroy(), self._cancel_step1()])

        # Danger zone
        section_label(w, "MORE", padx=20, pady=(12, 4))
        self._settings_row(w, "Privacy Policy", "", None)
        self._settings_row(w, "Terms of Service", "", None)
        self._settings_row(w, "Delete Account", "",
                           lambda: self._delete_account_flow(w))
        self._settings_row(w, "Sign Out", "",
                           lambda: [w.destroy(),
                                    self.controller.show_frame("LoginPage")],
                           danger=True)

    def _settings_row(self, parent, label, value, cmd, danger=False):
        row = tk.Frame(parent, bg=CARD,
                       highlightthickness=1, highlightbackground="#1A1A1A",
                       cursor="hand2" if cmd else "arrow")
        row.pack(fill="x", padx=20, pady=2)
        ri = tk.Frame(row, bg=CARD, padx=16, pady=12); ri.pack(fill="x")
        col = RED if danger else MUTED2
        lbl = tk.Label(ri, text=label, fg=col, bg=CARD, font=("Helvetica", 11))
        lbl.pack(side="left")
        if value:
            tk.Label(ri, text=value, fg="#444", bg=CARD,
                     font=("Helvetica", 10)).pack(side="right", padx=(0, 4))
        tk.Label(ri, text="›", fg="#333", bg=CARD,
                 font=("Helvetica", 14)).pack(side="right")
        if cmd:
            for wgt in (row, ri, lbl):
                wgt.bind("<Button-1>", lambda e, c=cmd: c())

    def _toggle_notifications(self):
        self.user.notif_enabled = self._notif_var.get()
        if not self.user.notif_enabled:
            self._notif_warning.pack(padx=20, pady=(0, 4))
        else:
            self._notif_warning.pack_forget()

    def _delete_account_flow(self, settings_win):
        settings_win.destroy()
        w = make_modal(self, h=420, title="Delete Account")
        tk.Label(w, text="Are you sure?", fg=RED, bg=BG,
                 font=("Helvetica", 18, "bold")).pack(pady=(36, 10))
        tk.Label(w,
                 text="Deleting your account will not cancel any outstanding "
                      "BNPL payments or repayment obligations. You will still "
                      "be charged for all active plans.",
                 fg=MUTED, bg=BG, font=("Helvetica", 10),
                 wraplength=330, justify="center").pack(pady=10)
        flat_btn(w, "Keep My Account", GREEN, "#000", lambda: w.destroy())
        subtle_link(w, "Yes, delete my account — I understand I still owe money",
                    lambda: [w.destroy(),
                             self.show_toast("Account deleted. Charges continue.", RED)])

