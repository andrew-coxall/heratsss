        self.amount_entry.pack(pady=5, padx=60, ipady=10)

        self.create_modern_btn("Cash Out Now", "#7042F4", self.do_loan)
        self.create_modern_btn("Buy Now, Pay Later", "#333333", self.do_bnpl)
        self.create_modern_btn("Instant Gamble", "#FF4500", self.do_gamble)

        tk.Label(self, text="RECENT ACTIVITY", fg="#555", bg="#121212", font=("Helvetica", 8, "bold")).pack(pady=(15, 5))
