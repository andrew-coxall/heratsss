        seed = [
            ("• Cash Out (Lightning): +$100.00", GREEN),
            ("• Auto-Repayment Debited: -$100.00", RED),
            ("• SwiftPay+ Membership: -$1.99", RED),
            ("• Klarna BNPL Auto-Debit: -$18.74", RED),
            ("• Community Tip: -$9.00", ORANGE),
            ("• Cash Out (Standard): +$75.00", GREEN),
