    # ── BNPL DEBT TRACKER ────────────────────────────────────
    def _build_bnpl_tracker(self):
        section_label(self.body, "ACTIVE PLANS")
        self._bnpl_frame = tk.Frame(self.body, bg=BG)
        self._bnpl_frame.pack(fill="x", padx=20)
        self._bnpl_plans = []  # list of (widget, remaining_payments, amount)
        self._refresh_bnpl_tracker()

    def _refresh_bnpl_tracker(self):
        for w in self._bnpl_frame.winfo_children():
            w.destroy()
        if not self._bnpl_plans:
            tk.Label(self._bnpl_frame,
                     text="No active BNPL plans  ·  Use Buy Now, Pay Later to start",
                     fg="#2A2A2A", bg=BG, font=("Helvetica", 9)).pack(pady=4)
        for plan in self._bnpl_plans:
            name, pmt, remaining, total = plan
            row = tk.Frame(self._bnpl_frame, bg=CARD,
                           highlightthickness=1, highlightbackground=BORDER)
            row.pack(fill="x", pady=3)
            ri = tk.Frame(row, bg=CARD, padx=14, pady=10); ri.pack(fill="x")
            tk.Label(ri, text=name, fg=WHITE, bg=CARD,
                     font=("Helvetica", 10, "bold")).pack(anchor="w")
            info_row = tk.Frame(ri, bg=CARD); info_row.pack(fill="x")
            tk.Label(info_row,
                     text=f"${pmt:.2f} × {remaining} payments remaining",
                     fg=MUTED2, bg=CARD, font=("Helvetica", 9)).pack(side="left")
            tk.Label(info_row, text=f"${pmt*remaining:.2f} owed",
                     fg=RED, bg=CARD,
                     font=("Helvetica", 9, "bold")).pack(side="right")
            # Progress bar
            paid = total - (pmt * remaining)
            progress = paid / total if total > 0 else 0
            pb_bg = tk.Frame(ri, bg="#222", height=4)
            pb_bg.pack(fill="x", pady=(6, 0))
            pb_bg.update_idletasks()
            fill_w = int(pb_bg.winfo_reqwidth() * progress)
            tk.Frame(pb_bg, bg=UE_GREEN, height=4, width=max(fill_w, 4)).place(x=0, y=0)

    # ── ACTIVITY FEED ────────────────────────────────────────
