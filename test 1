class User:
    def __init__(self, name="Alice", initial_balance=487.23):
        self.name            = name
        self.balance         = initial_balance
        self.swift_score     = 612
        self.streak          = 3
        self.membership      = True
        self.membership_fee  = 1.99
        self.loans_taken     = 0
        self.total_borrowed  = 0.0
        self.total_fees_paid = 0.0
        self.bnpl_open       = 0     # open BNPL plans
        self.linked_bank     = "Chase ····4821"
        self.notif_enabled   = True
        self.spending        = {     # fake spending analytics
            "Food & Drink": 312.44,
            "Entertainment": 89.99,
            "Shopping": 204.17,
            "Transport": 67.50,
            "Other": 41.00,
        }

    def deposit(self, amount):  self.balance += amount
    def withdraw(self, amount): self.balance -= amount   # no floor — infinite debt


