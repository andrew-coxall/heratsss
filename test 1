        h = tk.Frame(self.body, bg=BG)
        h.pack(fill="x", padx=20, pady=(14, 4))
        tk.Label(h, text=f"Hi, {self.user.name} 👋",
                 fg=MUTED2, bg=BG, font=("Helvetica", 11)).pack(side="left")
        right = tk.Frame(h, bg=BG); right.pack(side="right")
        bell = tk.Label(right, text="🔔", bg=BG, font=("Helvetica", 15),
                        cursor="hand2")
        bell.pack(side="right", padx=(8, 0))
        bell.bind("<Button-1>", lambda e: self._show_notification_center())

    # ── LIMITED-TIME OFFER BANNER — scarcity + countdown ────
    def _build_limited_offer(self):
        self._offer_frame = tk.Frame(self.body, bg="#1A0D00",
                                     highlightthickness=1,
                                     highlightbackground="#3A1A00")
        self._offer_frame.pack(fill="x", padx=20, pady=4)
        oi = tk.Frame(self._offer_frame, bg="#1A0D00", padx=14, pady=10,
                      cursor="hand2")
        oi.pack(fill="x")
        top_row = tk.Frame(oi, bg="#1A0D00"); top_row.pack(fill="x")
        tk.Label(top_row, text="🔥  LIMITED OFFER", fg=ORANGE, bg="#1A0D00",
                 font=("Helvetica", 9, "bold")).pack(side="left")
        self._countdown_var = tk.StringVar(value="Expires in 14:59")
        tk.Label(top_row, textvariable=self._countdown_var,
                 fg=RED, bg="#1A0D00",
                 font=("Helvetica", 9, "bold")).pack(side="right")
        tk.Label(oi, text="Double your cash-out limit — today only!",
                 fg=WHITE, bg="#1A0D00",
                 font=("Helvetica", 10, "bold")).pack(anchor="w")
        tk.Label(oi, text="Tap to activate · Offer expires when timer runs out",
                 fg="#554433", bg="#1A0D00",
                 font=("Helvetica", 8)).pack(anchor="w")
        for widget in [self._offer_frame, oi, top_row] + list(oi.winfo_children()):
            widget.bind("<Button-1>",
                        lambda e: self.show_toast(
                            "Limit doubled! Get cash now ⚡", ORANGE))
        self._countdown_secs = 899
        self._tick_countdown()

    def _tick_countdown(self):
        if self._countdown_secs > 0:
            self._countdown_secs -= 1
            m, s = divmod(self._countdown_secs, 60)
            self._countdown_var.set(f"Expires in {m:02d}:{s:02d}")
            self._countdown_id = self.after(1000, self._tick_countdown)

    # ── SWIFTSCORE ───────────────────────────────────────────
