                 fg=MUTED2, bg=BG, font=("Helvetica", 10), justify="center").pack(pady=(0, 16))
        ci = card_frame(w, padx=24, pady=0)
        tk.Label(ci, text="Balance Shield has your back 🛡️",
                 fg=GREEN, bg=CARD, font=("Helvetica", 12, "bold")).pack()
        tk.Label(ci, text="Advance $100 automatically to protect\nyou from overdraft fees.",
                 fg="#666", bg=CARD, font=("Helvetica", 9), justify="center").pack(pady=8)
        flat_btn(w, "Activate — Get $100 Now", GREEN, "#000",
                 lambda: [w.destroy(), self._trigger_shield()])
        subtle_link(w, "No thanks, I'll risk the overdraft")

    def _trigger_shield(self):
