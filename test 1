    #  TOAST / LOG
    # ────────────────────────────────────────────────────────
    def show_toast(self, msg, color=GREEN):
        self.toast.config(text=msg, bg=color)
        self.toast.pack(fill="x", before=self.winfo_children()[1])
        self.after(3500, self.toast.pack_forget)

    def log(self, msg, positive=True):
        self.feed.insert(0, f"• {msg}")
        self.feed.itemconfig(0, fg=GREEN if positive else RED)

