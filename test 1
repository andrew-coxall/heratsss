    def _execute_cashout(self, amt, speed_fee, tip):
        total_fee = speed_fee + tip
        self.user.balance -= total_fee
        self.user.deposit(amt)
        self.user.loans_taken    += 1
        self.user.total_borrowed += amt
        self.user.total_fees_paid += total_fee
        self.user.swift_score = min(850, self.user.swift_score + 4)
        self.refresh_balance()
        self.score_var.set(str(self.user.swift_score))
        self.log(f"Cash Out: +${amt:.2f}", True)
        if total_fee: self.log(f"Fees + Tip: -${total_fee:.2f}", False)
        self.show_toast(f"${amt:.2f} on its way! 🎉")
        self.after(5000, lambda: self._simulate_repayment(amt))

    def _simulate_repayment(self, amt):
        self.user.balance -= amt
        self.user.streak  += 1
        self.refresh_balance()
        self.log(f"Auto-Repayment: -${amt:.2f}", False)
        self.show_toast("Repayment auto-debited.", RED)
        if self.user.balance < 150:
            self.after(3500, self._balance_shield_prompt)

