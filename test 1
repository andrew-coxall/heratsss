# ═══════════════════════════════════════════════════════════════
#  1. DATA MODEL
# ═══════════════════════════════════════════════════════════════
class User:
    def __init__(self, name="Alice", initial_balance=487.23):
        self.name           = name
        self.balance        = initial_balance
        self.swift_score    = 612
        self.streak         = 3
        self.membership     = True
        self.membership_fee = 1.99
        self.loans_taken    = 0

    def deposit(self, amount):  self.balance += amount
    def withdraw(self, amount): self.balance -= amount   # no floor — infinite debt

# ═══════════════════════════════════════════════════════════════
#  2. CONTROLLER / ROOT
# ═══════════════════════════════════════════════════════════════
class SwiftPayApp(tk.Tk):
    def __init__(self):
        super().__init__()
        self.title("SwiftPay")
        self.geometry("400x760")
        self.resizable(True, True)
        self.configure(bg="#0D0D0D")

        self.user = User()

        self.container = tk.Frame(self, bg="#0D0D0D")
        self.container.pack(fill="both", expand=True)
        self.container.grid_rowconfigure(0, weight=1)
        self.container.grid_columnconfigure(0, weight=1)

        self.frames = {}
        for F in (LoginPage, DashboardPage):
            f = F(parent=self.container, controller=self)
            self.frames[F.__name__] = f
            f.grid(row=0, column=0, sticky="nsew")

        self.show_frame("LoginPage")

    def show_frame(self, name):
        self.frames[name].tkraise()

    @staticmethod
    def make_modal(root, w=390, h=700, title="SwiftPay"):
        win = tk.Toplevel(root)
        win.geometry(f"{w}x{h}")
        win.resizable(False, False)
        win.configure(bg="#0D0D0D")
        win.transient(root)
        win.grab_set()
        bar = tk.Frame(win, bg="#161616", pady=13)
        bar.pack(fill="x")
        tk.Label(bar, text=title, fg="#FFFFFF", bg="#161616",
                 font=("Helvetica", 13, "bold")).pack()
        return win

    @staticmethod
    def flat_btn(parent, text, bg, fg, cmd, pady=14, font_size=12):
        f = tk.Frame(parent, bg=bg, cursor="hand2")
        f.pack(pady=6, padx=30, fill="x")
        l = tk.Label(f, text=text, fg=fg, bg=bg,
                     font=("Helvetica", font_size, "bold"), pady=pady)
        l.pack()
        for w in (f, l):
            w.bind("<Button-1>", lambda e, c=cmd: c())
        return f

# ═══════════════════════════════════════════════════════════════
#  3. LOGIN PAGE
# ═══════════════════════════════════════════════════════════════
class LoginPage(tk.Frame):
    def __init__(self, parent, controller):
        super().__init__(parent, bg="#0D0D0D")
        self.controller = controller

        tk.Label(self, text="SwiftPay", fg="#00D47E", bg="#0D0D0D",
                 font=("Helvetica", 44, "bold")).pack(pady=(90, 4))
        tk.Label(self, text="Your money, when you need it.",
                 fg="#555", bg="#0D0D0D", font=("Helvetica", 11)).pack()

        self.pin = tk.Entry(self, show="●", justify="center",
                            font=("Helvetica", 28), bg="#1A1A1A", fg="white",
                            bd=0, insertbackground="white",
                            highlightthickness=1, highlightcolor="#333")
        self.pin.pack(pady=34, padx=50, ipady=12)
        self.pin.insert(0, "1234")

        SwiftPayApp.flat_btn(self, "Sign In", "#00D47E", "#000",
                             self._login, font_size=13)

        # Membership auto-enrol in near-invisible fine print
        tk.Label(self, wraplength=320,
                 text="By signing in you agree to SwiftPay's Terms of Service "
                      "and authorize a $1.99/month SwiftPay+ membership "
                      "charged to your linked account. Cancel anytime in "
                      "Settings > Membership.",
                 fg="#1A1A1A", bg="#0D0D0D",
                 font=("Helvetica", 6)).pack(side="bottom", pady=12)

    def _login(self):
        if self.pin.get() == "1234":
            self.controller.show_frame("DashboardPage")
            self.controller.frames["DashboardPage"]._start_notification_drip()
        else:
            messagebox.showerror("", "Incorrect PIN  (hint: 1234)")

