        self.balance_var.set(f"${self.user.balance:,.2f}")

    # ────────────────────────────────────────────────────────
    #  PUSH NOTIFICATION DRIP
    # ────────────────────────────────────────────────────────
    def _start_notification_drip(self):
        schedule = [
            (5000,  "⚠️  Low balance detected. Tap to get cash now.", RED),
            (15000, "🔥  SwiftScore could be HIGHER — borrow today.", PURPLE),
            (27000, "💸  418 members cashed out today. Don't miss out!", GREEN),
            (41000, "⏰  Repayment due soon. Avoid overdraft — act now.", RED),
            (58000, "🎁  1 advance away from unlocking $250 limit!", ORANGE),
            (75000, "🃏  You have a FREE spin waiting in the Casino!", RED),
        ]
        for delay, msg, color in schedule:
            self.after(delay, lambda m=msg, c=color: self._show_push(m, c))

    def _show_push(self, msg, color):
        w = tk.Toplevel(self)
        w.geometry("370x90+14+26")
        w.configure(bg=color)
        w.overrideredirect(True)
        w.attributes("-topmost", True)
        inner = tk.Frame(w, bg=color, padx=14, pady=10)
        inner.pack(fill="both", expand=True)
        top = tk.Frame(inner, bg=color); top.pack(fill="x")
        tk.Label(top, text="SwiftPay", fg=WHITE, bg=color,
                 font=("Helvetica", 9, "bold")).pack(side="left")
        tk.Label(top, text="now", fg=WHITE, bg=color,
                 font=("Helvetica", 8)).pack(side="right")
        tk.Label(inner, text=msg, fg=WHITE, bg=color,
                 font=("Helvetica", 10), wraplength=330).pack(anchor="w")
        w.bind("<Button-1>", lambda e: [w.destroy(), self.do_loan()])
        self.after(4500, lambda: w.destroy() if w.winfo_exists() else None)

    def _show_notification_center(self):
        w = make_modal(self, h=560, title="Notifications")
        entries = [
            ("⚠️  Repayment auto-debited  ·  just now",         RED),
            ("🔥  SwiftScore up 4 pts  ·  1h ago",              GREEN),
            ("💸  Klarna payment due in 2 days  ·  2h ago",     ORANGE),
            ("⚠️  Balance below $50  ·  5h ago",                RED),
            ("🎁  Unlock $150 limit — 1 advance away  ·  8h ago", PURPLE),
            ("⏰  Repayment due in 2 days  ·  1d ago",          ORANGE),
            ("🃏  Free Casino spin waiting  ·  2d ago",          RED),
        ]
        for txt, color in entries:
            row = tk.Frame(w, bg=CARD,
                           highlightthickness=1, highlightbackground="#1A1A1A")
            row.pack(fill="x", padx=18, pady=2)
            tk.Label(row, text=txt, fg=color, bg=CARD,
                     font=("Helvetica", 10), padx=14, pady=12,
                     anchor="w").pack(fill="x")

    # ════════════════════════════════════════════════════════
    #  CASH-OUT FLOW (Earnin)
    # ════════════════════════════════════════════════════════
