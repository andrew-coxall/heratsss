    # ── ACTIVITY FEED ────────────────────────────────────────
    def _build_activity_feed(self):
        tk.Label(self.body, text="RECENT ACTIVITY", fg="#333", bg="#0D0D0D",
                 font=("Helvetica", 8, "bold")).pack(anchor="w", padx=24, pady=(14, 4))
        self.feed = tk.Listbox(self.body, bg="#0D0D0D", fg="#CCC",
                               borderwidth=0, highlightthickness=0,
                               font=("Helvetica", 10),
                               selectbackground="#0D0D0D", height=5)
        self.feed.pack(fill="x", padx=24, pady=(0, 10))
