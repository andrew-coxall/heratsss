        self.dealer_score_label = tk.Label(self.bj_window, text=" 0 ", fg="white", bg="#0F1822", font=("Helvetica", 12, "bold"), padx=10, pady=2)
        self.dealer_score_label.pack()

        self.chip_canvas = tk.Canvas(self.bj_window, width=80, height=80, bg="#1A2837", highlightthickness=0)
        self.chip_canvas.pack(pady=30)
