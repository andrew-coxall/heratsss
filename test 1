    # ── BOTTOM NAV ───────────────────────────────────────────
    def _build_bottom_nav(self):
        nav = tk.Frame(self.body, bg="#161616",
                       highlightthickness=1, highlightbackground="#222")
        nav.pack(fill="x", padx=20, pady=(8, 20))
        ni = tk.Frame(nav, bg="#161616"); ni.pack(fill="x", pady=10)
        items = [("🏠\nHome",     None),
                 ("📊\nActivity", None),
                 ("👤\nProfile",  self._show_profile),
                 ("⚙️\nSettings", self._show_settings)]
        for txt, cmd in items:
            lbl = tk.Label(ni, text=txt,
                           fg="#555" if not cmd else "#888",
                           bg="#161616", font=("Helvetica", 8),
                           cursor="hand2" if cmd else "arrow",
                           justify="center")
            lbl.pack(side="left", expand=True)
            if cmd:
                lbl.bind("<Button-1>", lambda e, c=cmd: c())

    # ── TOAST ────────────────────────────────────────────────
    def show_toast(self, msg, color="#00D47E"):
        self.toast.config(text=msg, bg=color)
        self.toast.pack(fill="x", before=self.winfo_children()[1])
        self.after(3200, self.toast.pack_forget)

    def log(self, msg, positive=True):
        self.feed.insert(0, f"• {msg}")
        self.feed.itemconfig(0, fg="#00D47E" if positive else "#FF4500")

    def refresh_balance(self):
        self.balance_var.set(f"${self.user.balance:,.2f}")

    # ── PUSH NOTIFICATION DRIP ───────────────────────────────
    def _start_notification_drip(self):
        schedule = [
            (6000,  "⚠️  Low balance detected. Tap to get cash now.",     "#FF4500"),
            (16000, "🔥  Your SwiftScore could be HIGHER. Borrow today.", "#7042F4"),
            (28000, "💸  418 members cashed out today — don't miss out!", "#00D47E"),
            (42000, "⏰  Repayment due soon. Avoid overdraft — act now.",  "#FF4500"),
            (60000, "🎁  1 advance away from unlocking $250 limit!",       "#FF8C00"),
        ]
        for delay, msg, color in schedule:
            self.after(delay, lambda m=msg, c=color: self._show_push(m, c))

    def _show_push(self, msg, color):
        # Borderless overlay — looks like a real OS push notification
        w = tk.Toplevel(self)
        w.geometry("370x88+15+28")
        w.configure(bg=color)
        w.overrideredirect(True)
        w.attributes("-topmost", True)
        inner = tk.Frame(w, bg=color, padx=14, pady=10)
        inner.pack(fill="both", expand=True)
        tk.Label(inner, text="SwiftPay", fg="white", bg=color,
                 font=("Helvetica", 9, "bold")).pack(anchor="w")
        tk.Label(inner, text=msg, fg="white", bg=color,
                 font=("Helvetica", 10), wraplength=330).pack(anchor="w")
        w.bind("<Button-1>", lambda e: [w.destroy(), self.do_loan()])
        self.after(4500, lambda: w.destroy() if w.winfo_exists() else None)

    def _show_notification_center(self):
        w = SwiftPayApp.make_modal(self, h=520, title="Notifications")
        entries = [
            ("⚠️  Repayment auto-debited  ·  2m ago",        "#FF4500"),
            ("🔥  SwiftScore increased by 4 pts  ·  1h ago",  "#00D47E"),
            ("💸  Friend joined via your link  ·  3h ago",    "#00D47E"),
            ("⚠️  Balance below $50  ·  5h ago",              "#FF4500"),
            ("🎁  New offer: unlock $150 limit  ·  8h ago",   "#7042F4"),
            ("⏰  Repayment due in 2 days  ·  1d ago",        "#FF8C00"),
        ]
        for txt, color in entries:
            row = tk.Frame(w, bg="#161616",
                           highlightthickness=1, highlightbackground="#222")
            row.pack(fill="x", padx=20, pady=3)
            tk.Label(row, text=txt, fg=color, bg="#161616",
                     font=("Helvetica", 10), padx=14, pady=12,
                     anchor="w").pack(fill="x")

    # ════════════════════════════════════════════════════════
    #  CASH-OUT FLOW
    # ════════════════════════════════════════════════════════
    def do_loan(self):
        try:
            amt = float(self.amount_entry.get())
            if amt <= 0: raise ValueError
        except ValueError:
            self.show_toast("Enter a valid amount", "#FF4500"); return
        self._screen1_amount(amt)

    # Screen 1 — "your money" framing + bait-and-switch offer
    def _screen1_amount(self, requested):
        w = SwiftPayApp.make_modal(self, h=680, title="Cash Out")

        tk.Label(w, text="Access Your Earned Pay",
                 fg="#00D47E", bg="#0D0D0D",
                 font=("Helvetica", 20, "bold")).pack(pady=(28, 4))
        tk.Label(w, text="This is money you've already worked for.\nNo interest. No credit check.",
                 fg="#555", bg="#0D0D0D", font=("Helvetica", 10),
                 justify="center").pack()

        # Bait-and-switch: advertise $500, offer $25 for new users
        actual = 25 if self.user.loans_taken == 0 else min(requested, 75)
        card = tk.Frame(w, bg="#161616",
                        highlightthickness=1, highlightbackground="#222")
        card.pack(fill="x", padx=25, pady=20)
        ci = tk.Frame(card, bg="#161616", padx=20, pady=22); ci.pack(fill="x")
        tk.Label(ci, text="YOUR OFFER", fg="#555", bg="#161616",
                 font=("Helvetica", 8, "bold")).pack()
        tk.Label(ci, text=f"${actual:.2f}", fg="white", bg="#161616",
                 font=("Helvetica", 44, "bold")).pack()
        if actual < requested:
            tk.Label(ci,
                     text=f"Your limit is ${actual:.2f} based on your earnings history.\n"
                          "Repay on time to unlock higher amounts.",
                     fg="#555", bg="#161616", font=("Helvetica", 9),
                     justify="center").pack(pady=(4, 0))

        tk.Label(w, text="🔥  418 members accessed pay in the last hour",
                 fg="#00D47E", bg="#0D0D0D", font=("Helvetica", 9)).pack(pady=4)

        SwiftPayApp.flat_btn(w, "Get My Money →", "#00D47E", "#000",
                             lambda: [w.destroy(), self._screen2_speed(actual)])

        # Repayment auto-debit in near-invisible text
        tk.Label(w,
                 text=f"${actual:.2f} will be automatically debited from your linked bank "
                      "account on your next payday. Missed payday may result in overdraft "
                      "fees charged by your bank.",
                 fg="#1C1C1C", bg="#0D0D0D", font=("Helvetica", 6),
                 wraplength=340, justify="center").pack(side="bottom", pady=10)

    # Screen 2 — Speed selector (Lightning fee hides APR)
    def _screen2_speed(self, amt):
        w = SwiftPayApp.make_modal(self, h=600, title="Transfer Speed")

        tk.Label(w, text="When do you need it?", fg="white", bg="#0D0D0D",
                 font=("Helvetica", 17, "bold")).pack(pady=(26, 6))

        speed_fee = round(3.99 if amt <= 75 else 5.99, 2)

        # Lightning — visually dominant, purple border
        lo = tk.Frame(w, bg="#7042F4", padx=2, pady=2)
        lo.pack(fill="x", padx=25, pady=(16, 6))
        li = tk.Frame(lo, bg="#1A1A1A", padx=16, pady=16, cursor="hand2")
        li.pack(fill="x")
        row = tk.Frame(li, bg="#1A1A1A"); row.pack(fill="x")
        tk.Label(row, text="⚡  Lightning Speed", fg="white", bg="#1A1A1A",
                 font=("Helvetica", 13, "bold")).pack(side="left")
        tk.Label(row, text="RECOMMENDED", fg="#7042F4", bg="#1A1A1A",
                 font=("Helvetica", 8, "bold")).pack(side="right")
        tk.Label(li, text="Arrives in ~30 minutes",
                 fg="#00D47E", bg="#1A1A1A", font=("Helvetica", 10)).pack(anchor="w")
        tk.Label(li, text=f"Small fee: ${speed_fee:.2f}",
                 fg="#888", bg="#1A1A1A", font=("Helvetica", 9)).pack(anchor="w")
        all_widgets = [lo, li, row] + list(li.winfo_children()) + list(row.winfo_children())
        for widget in all_widgets:
            widget.bind("<Button-1>",
                        lambda e: [w.destroy(),
                                   self._screen3_healthy_meals(amt, speed_fee, True)])

        # Standard — muted, de-emphasised
        so = tk.Frame(w, bg="#1A1A1A", padx=16, pady=14, cursor="hand2")
        so.pack(fill="x", padx=25, pady=4)
        tk.Label(so, text="Standard Transfer", fg="#666", bg="#1A1A1A",
                 font=("Helvetica", 11)).pack(anchor="w")
        tk.Label(so, text="1–3 business days  ·  Free",
                 fg="#444", bg="#1A1A1A", font=("Helvetica", 9)).pack(anchor="w")
        for widget in [so] + list(so.winfo_children()):
            widget.bind("<Button-1>",
                        lambda e: [w.destroy(),
                                   self._screen3_healthy_meals(amt, 0, False)])

        # Effective APR hidden in near-invisible ink
        apr = round((speed_fee / amt) * (365 / 14) * 100)
        tk.Label(w,
                 text=f"* Lightning Speed fee equivalent to ~{apr}% APR on a 14-day term.",
                 fg="#181818", bg="#0D0D0D", font=("Helvetica", 6),
                 justify="center").pack(side="bottom", pady=8)

