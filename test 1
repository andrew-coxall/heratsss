            ("• Cash Out: +$100.00",      "#00D47E"),
            ("• Auto-Repayment: -$100.00","#FF4500"),
            ("• SwiftPay+ Fee: -$1.99",   "#FF4500"),
            ("• Cash Out: +$75.00",       "#00D47E"),
            ("• Community Tip: -$9.00",   "#FF6500"),
        ]:
