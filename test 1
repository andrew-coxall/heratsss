        self.chip_canvas.create_oval(15, 15, 65, 65, outline="#0A84FF", width=1, dash=(4, 4))
        self.chip_text = self.chip_canvas.create_text(40, 40, text=f"${self.bet:,.0f}", font=("Helvetica", 14, "bold"), fill="white")

        self.player_card_frame = tk.Frame(self.bj_window, bg="#1A2837")
