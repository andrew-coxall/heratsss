class LoginPage(tk.Frame):
    def __init__(self, parent, controller):
        super().__init__(parent, bg=BG)
        self.controller = controller

        # Logo
        tk.Label(self, text="SwiftPay", fg=GREEN, bg=BG,
                 font=("Helvetica", 46, "bold")).pack(pady=(80, 4))
        tk.Label(self, text="Your money, when you need it.",
                 fg=MUTED, bg=BG, font=("Helvetica", 11)).pack()

        # Fake trust badges
        badges = tk.Frame(self, bg=BG); badges.pack(pady=12)
        for badge in ["🔒 Bank-level security", "⚡ Instant access", "✅ FDIC partner"]:
            tk.Label(badges, text=badge, fg="#2A2A2A", bg=BG,
                     font=("Helvetica", 8)).pack(side="left", padx=8)

        # PIN entry
        self.pin = tk.Entry(self, show="●", justify="center",
                            font=("Helvetica", 28), bg=CARD2, fg=WHITE,
                            bd=0, insertbackground=WHITE,
                            highlightthickness=1,
                            highlightbackground=BORDER,
                            highlightcolor=GREEN)
        self.pin.pack(pady=28, padx=50, ipady=13)
        self.pin.insert(0, "1234")

        flat_btn(self, "Sign In", GREEN, "#000", self._login, font_size=13)

        # Biometric option — looks like real app, does nothing
        bio = tk.Label(self, text="Use Face ID instead",
                       fg="#2A2A2A", bg=BG, font=("Helvetica", 9, "underline"),
                       cursor="hand2")
        bio.pack(pady=4)

        # Membership auto-enrol — near-invisible
        tk.Label(self, wraplength=320,
                 text="By signing in you agree to SwiftPay's Terms of Service and "
                      "authorize a recurring $1.99/month SwiftPay+ membership charged "
                      "to your linked account. Cancel anytime in Settings > Membership. "
                      "SwiftPay is not a bank. Not FDIC insured.",
                 fg="#161616", bg=BG,
                 font=("Helvetica", 6)).pack(side="bottom", pady=12, padx=20)

    def _login(self):
        if self.pin.get() == "1234":
            self.controller.show_frame("DashboardPage")
            db = self.controller.frames["DashboardPage"]
            db._start_notification_drip()
            # Silent $1.99 membership debit on login
            self.controller.user.balance -= 1.99
        else:
            messagebox.showerror("", "Incorrect PIN  (hint: 1234)")


