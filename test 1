        tk.Label(self, text="Set Amount", fg="#AAA", bg="#121212", font=("Helvetica", 9, "bold")).pack(pady=(5, 5))
        self.amount_entry = tk.Entry(self, justify="center", font=("Helvetica", 22), bg="#000", fg="#00D084", borderwidth=0, insertbackground="white")
