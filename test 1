        self.bj_bal_lbl.pack(anchor="w")

        self.bj_pnl_lbl = tk.Label(stats_frame, text="Session P/L: $0.00", fg="#AAA", bg="#1A2837", font=("Helvetica", 10))
        self.bj_pnl_lbl.pack(anchor="w")

        exit_btn = tk.Label(self.header_frame, text="✖", fg="#888", bg="#1A2837", font=("Helvetica", 20, "bold"), cursor="hand2")
