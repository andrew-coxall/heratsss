        tk.Button(self, text="Secure Sign Out", command=lambda: controller.show_frame("LoginPage"),
                  bg="#121212", fg="#444", bd=0, font=("Helvetica", 9, "underline")).pack(side="bottom", pady=10)

    def create_modern_btn(self, text, color, cmd, parent=None):
        target = parent if parent else self
        f = tk.Frame(target, bg=color, cursor="hand2")
        f.pack(pady=5, padx=40, fill="x")
        l = tk.Label(f, text=text, fg="white", bg=color, font=("Helvetica", 11, "bold"), pady=12)
        l.pack()
        f.bind("<Button-1>", lambda e: cmd())
        l.bind("<Button-1>", lambda e: cmd())
        return f

    def show_tip_modal(self, amount):
        self.modal = tk.Toplevel(self)
        self.modal.geometry("380x550")
        self.modal.configure(bg="#1E1E1E")
        self.modal.transient(self)
        self.modal.grab_set()

        tk.Label(self.modal, text="Pay it Forward", fg="#00D084", bg="#1E1E1E", font=("Helvetica", 20, "bold")).pack(pady=(30, 10))
        guilt_text = ("Most SwiftPay members tip $5 or more\nto help keep this service interest-free\n"
                      "for the community.")
        tk.Label(self.modal, text=guilt_text, fg="#AAA", bg="#1E1E1E", font=("Helvetica", 10)).pack(pady=5)

        tk.Label(self.modal, text="RECOMMENDED FOR YOU", fg="#7042F4", bg="#1E1E1E", font=("Helvetica", 8, "bold")).pack(pady=(20, 0))
        self.create_tip_option("$10 Tip", "#7042F4", 10, amount, is_recommended=True)
        self.create_tip_option("$5 Tip", "#333", 5, amount)
        self.create_tip_option("$2 Tip", "#333", 2, amount)

        tk.Label(self.modal, text="I don't want to support the community", fg="#444", bg="#1E1E1E", font=("Helvetica", 8)).pack(pady=(20, 0))
        f_no = tk.Frame(self.modal, bg="#1E1E1E", cursor="hand2")
        f_no.pack(pady=5)
        l_no = tk.Label(f_no, text="Skip Tip & Continue", fg="#666", bg="#1E1E1E",
                        font=("Helvetica", 10, "underline"), pady=5)
        l_no.pack()

        def skip():
            self.current_tip = 0
            self.modal.destroy()
            self.execute_cash_out(amount)

        f_no.bind("<Button-1>", lambda e: skip())
        l_no.bind("<Button-1>", lambda e: skip())

    def create_tip_option(self, text, color, tip_val, original_amt, is_recommended=False):
        highlight = "#7042F4" if is_recommended else "#333"
        f = tk.Frame(self.modal, bg=highlight, cursor="hand2", padx=2 if is_recommended else 0, pady=2 if is_recommended else 0)
        f.pack(pady=5, padx=50, fill="x")
        l = tk.Label(f, text=text, fg="white", bg=color, font=("Helvetica", 11, "bold"), pady=15)
        l.pack(fill="x")

        def select_tip():
            self.current_tip = tip_val
            self.modal.destroy()
            self.show_notification(f"Generous! ${tip_val} tip added.", "#7042F4")
            self.execute_cash_out(original_amt)

        f.bind("<Button-1>", lambda e: select_tip())
        l.bind("<Button-1>", lambda e: select_tip())

    def do_loan(self):
        try:
            amt = float(self.amount_entry.get())
            self.show_tip_modal(amt)
        except ValueError:
            self.show_notification("Invalid Amount", "#FF4500")

    def execute_cash_out(self, amt):
        self.show_notification("Processing Transfer...", "#7042F4")

        def finish():
            total_deduction = self.current_tip
            if self.user.withdraw(total_deduction):
                self.user.deposit(amt)
                self.update_ui()
                self.log_act(f"Cash Out: +${amt:,.2f}", True)
                if self.current_tip > 0:
                    self.log_act(f"Community Tip: -${self.current_tip:,.2f}", False)
                self.show_notification(f"Success! ${amt} sent to bank.")
            else:
                self.show_notification("Insufficient funds for tip!", "#FF4500")

        self.after(1500, finish)

    def show_notification(self, message, color="#00D084"):
        self.status_bar.config(text=message, bg=color)
        self.status_bar.pack(fill="x", side="top", before=self.card)
        self.after(3000, self.status_bar.pack_forget)

    def log_act(self, msg, pos=True):
        color = "#00D084" if pos else "#FF4500"
        self.history_list.insert(0, f"• {msg}")
        self.history_list.itemconfig(0, fg=color)

    def update_ui(self):
        self.balance_var.set(f"${self.user.balance:,.2f}")

    def do_bnpl(self):
        try:
            amt = float(self.amount_entry.get())
            if self.user.withdraw(amt / 4):
                self.update_ui()
                self.log_act(f"BNPL Payment: -${amt/4:,.2f}", False)
                self.show_notification("Payment Confirmed", "#333")
        except:
            pass

    def do_gamble(self):
        try:
            amt = float(self.amount_entry.get())
            if amt <= 0:
                self.show_notification("Enter a bet amount", "#FF4500")
                return
            # Allow infinite debt — no balance check
            self.user.balance -= amt
            self.update_ui()
            self.log_act(f"Blackjack Bet: -${amt:,.2f}", False)
            self.open_blackjack(amt)
        except ValueError:
            self.show_notification("Invalid Bet Amount", "#FF4500")

