    def _klarna_auto_debit(self, amount, idx):
        self.user.balance -= amount
        self.refresh_balance()
        # Update tracker
        if self._bnpl_plans:
            name, pmt, remaining, total = self._bnpl_plans[0]
            new_remaining = max(0, remaining - 1)
            self._bnpl_plans[0] = (name, pmt, new_remaining, total)
            if new_remaining == 0:
                self._bnpl_plans.pop(0)
                self.user.bnpl_open = max(0, self.user.bnpl_open - 1)
        self._refresh_bnpl_tracker()
        self.log(f"Klarna Auto-Debit #{idx}: -${amount:.2f}", False)
        self._show_push(
            f"⏰  Klarna payment #{idx} of ${amount:.2f} auto-debited.",
            "#CC6688")

