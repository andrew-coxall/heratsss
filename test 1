import random
import tkinter as tk
from tkinter import messagebox

# --- Logic Classes (Your original code, slightly modified for the UI) ---

class User:
    def __init__(self, name, initial_balance=1000):
        self.name = name
        self.balance = initial_balance

    def deposit(self, amount):
        self.balance += amount
        
    def withdraw(self, amount):
        if self.balance >= amount:
            self.balance -= amount
            return True
        return False

# --- GUI Application ---

class FinanceApp:
    def __init__(self, root):
        self.root = root
        self.root.title("Alice's Finance Simulator")
        self.root.geometry("400x450")
        
        # Initialize Logic
        self.user = User(name="Alice", initial_balance=2000)
        
        # UI Elements
        self.label_name = tk.Label(root, text=f"User: {self.user.name}", font=("Arial", 14, "bold"))
        self.label_name.pack(pady=10)

        self.balance_var = tk.StringVar()
        self.balance_var.set(f"Balance: ${self.user.balance:.2f}")
        
        self.label_balance = tk.Label(root, textvariable=self.balance_var, font=("Arial", 18), fg="green")
        self.label_balance.pack(pady=10)

        # Buttons
        tk.Button(root, text="Buy Now Pay Later ($150)", width=25, command=self.do_bnpl).pack(pady=5)
        tk.Button(root, text="Take Payday Loan ($300)", width=25, command=self.do_loan).pack(pady=5)
        tk.Button(root, text="Gamble ($100)", width=25, command=self.do_gamble, bg="orange").pack(pady=5)
        tk.Button(root, text="Reset Balance", width=25, command=self.reset).pack(pady=20)

    def update_ui(self):
        self.balance_var.set(f"Balance: ${self.user.balance:.2f}")

    def do_bnpl(self):
        cost = 150
        installment = cost / 3
        if self.user.withdraw(installment):
            messagebox.showinfo("Success", f"BNPL Started! First installment of ${installment:.2f} paid.")
            self.update_ui()
        else:
            messagebox.showwarning("Failed", "Insufficient funds for BNPL installment.")

    def do_loan(self):
        amount = 300
        fee = amount * 0.1
        if self.user.withdraw(fee):
            self.user.deposit(amount)
            messagebox.showinfo("Loan Approved", f"Loan of ${amount} received! Fee of ${fee} deducted.")
            self.update_ui()
        else:
            messagebox.showwarning("Failed", "You don't have enough to cover the loan fee.")

    def do_gamble(self):
        bet = 100
        if self.user.withdraw(bet):
            if random.choice([True, False]):
                winnings = bet * 2
                self.user.deposit(winnings)
                messagebox.showinfo("Winner!", f"You won ${winnings}!")
            else:
                messagebox.showerror("Loser", "Better luck next time!")
            self.update_ui()
        else:
            messagebox.showwarning("Failed", "Not enough money to bet.")

    def reset(self):
        self.user.balance = 2000
        self.update_ui()

if __name__ == "__main__":
    root = tk.Tk()
    app = FinanceApp(root)
    root.mainloop()
