        card = tk.Frame(self.body, bg="#161616",
                        highlightthickness=1, highlightbackground="#222")
        card.pack(fill="x", padx=20, pady=6)
        inner = tk.Frame(card, bg="#161616", padx=16, pady=14)
        inner.pack(fill="x")

        left = tk.Frame(inner, bg="#161616")
        left.pack(side="left")
        tk.Label(left, text="SwiftScore™", fg="#00D47E", bg="#161616",
                 font=("Helvetica", 9, "bold")).pack(anchor="w")
